class LiveSpatialWindow:
    def __init__(self, world_size: int, num_uavs: int, fov_radius: int):
        self.world_size = world_size
        self.num_uavs   = num_uavs
        self.fov_radius = fov_radius

        plt.ion()
        self._fig, self._axs = plt.subplots(1, 3, figsize=(17, 6),
                                             gridspec_kw={"wspace": 0.25})
        self._fig.suptitle("Thesis Evaluation — Spatial View", fontsize=13, fontweight="bold")

        for ax, title in zip(self._axs, [
            "P(FIRE) Belief Map\n(continuous posterior)",
            "Belief State Map\n(MAP estimate: healthy / fire / burned)",
            "Ground-Truth Wildfire State\n(healthy / fire / burned)",
        ]):
            ax.set_title(title, fontsize=8.5)
            ax.set_xlim(0, world_size - 1); ax.set_ylim(0, world_size - 1)
            ax.set_aspect("equal")
            ax.set_xlabel("y (col)", fontsize=8); ax.set_ylabel("x (row)", fontsize=8)

        blank = np.zeros((world_size, world_size))
        blank_s = np.full((world_size, world_size), HEALTHY, dtype=np.int32)

        self._im_prob = self._axs[0].imshow(blank, origin="lower", cmap="hot",
                                             vmin=0.0, vmax=1.0, interpolation="bilinear")
        plt.colorbar(self._im_prob, ax=self._axs[0], fraction=0.046, pad=0.04,
                     label="P(FIRE | z_{1:t})")
        self._im_belief = self._axs[1].imshow(blank_s, origin="lower", cmap=WILDFIRE_CMAP,
                                               vmin=0, vmax=2, interpolation="nearest")
        self._im_gt = self._axs[2].imshow(blank_s, origin="lower", cmap=WILDFIRE_CMAP,
                                           vmin=0, vmax=2, interpolation="nearest")

        from matplotlib.patches import Patch
        leg = [Patch(facecolor="#2e8b57", label="Healthy"),
               Patch(facecolor="#ff8c00", label="Fire"),
               Patch(facecolor="#000000", label="Burned")]
        for ax in self._axs[1:]:
            ax.legend(handles=leg, loc="upper right", fontsize=7, framealpha=0.7)

        self._traj_lines  = [[] for _ in range(num_uavs)]
        self._fov_rects   = [[] for _ in range(num_uavs)]
        self._drone_icons = [[] for _ in range(num_uavs)]

        for i in range(num_uavs):
            c = UAV_COLORS[i % len(UAV_COLORS)]
            # Add trajectory / FOV / drone art to panels 0 and 1 only.
            # Panel 2 (Ground Truth) stays clean — no robot overlays.
            for panel_idx, ax in enumerate(self._axs[:2]):
                line, = ax.plot([], [], color=c, linewidth=1.5, alpha=0.85,
                                label=f"UAV {i+1}" if panel_idx == 0 else "")
                self._traj_lines[i].append(line)
                rect = Rectangle((0, 0), 1, 1, fill=False, edgecolor=c,
                                  linewidth=1.1, linestyle="--", zorder=6)
                ax.add_patch(rect)
                self._fov_rects[i].append(rect)

        self._axs[0].legend(fontsize=7, loc="upper left", framealpha=0.7)
        try:
            self._fig.canvas.manager.window.wm_geometry("+820+0")
        except Exception:
            pass
        self._fig.canvas.draw(); plt.pause(0.001)

    def update(self, env: "FinalWildfireMonitoringEnv", t: int = 0):
        ws = self.world_size
        self._im_prob.set_data(env.belief_map[:, :, FIRE])
        self._im_belief.set_data(belief_to_display_state(env.belief_map))
        self._im_gt.set_data(env.true_state_map)

        for i in range(self.num_uavs):
            for art_list in self._drone_icons[i]:
                for art in art_list:
                    try: art.remove()
                    except Exception: pass
            self._drone_icons[i] = [[], []]  # panels 0 and 1 only

        for i in range(self.num_uavs):
            traj = np.asarray(env.trajs[i], dtype=float)
            pos  = env.robot_states[i]
            ci = int(np.clip(np.floor(pos[0]), 0, ws - 1))
            cj = int(np.clip(np.floor(pos[1]), 0, ws - 1))
            r  = self.fov_radius
            i0 = max(0, ci - r); i1 = min(ws - 1, ci + r)
            j0 = max(0, cj - r); j1 = min(ws - 1, cj + r)

            # Panels 0 and 1: trajectory, FOV rectangle, drone icon
            for panel_idx, ax in enumerate(self._axs[:2]):
                self._traj_lines[i][panel_idx].set_data(traj[:, 1], traj[:, 0])
                rect = self._fov_rects[i][panel_idx]
                rect.set_xy((j0, i0)); rect.set_width(max(1, j1 - j0 + 1))
                rect.set_height(max(1, i1 - i0 + 1))
                self._drone_icons[i][panel_idx] = draw_drone_icon(
                    ax=ax, x=float(cj), y=float(ci),
                    size=2.0, color=UAV_COLORS[i % len(UAV_COLORS)], zorder=9)

        self._fig.suptitle(f"Thesis Evaluation — Spatial View  [t = {t}]",
                           fontsize=13, fontweight="bold")
        self._fig.canvas.draw_idle(); plt.pause(0.001)


