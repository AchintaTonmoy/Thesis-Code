class LiveMetricsWindow:
    def __init__(self, duration: int, num_uavs: int):
        self.duration = duration
        self.num_uavs = num_uavs
        self.times:   List[int]         = []
        self.m1_hist: List[float]       = []
        self.m2_hist: List[float]       = []
        self.m3_hist: List[float]       = []
        self.m4_hist: List[List[float]] = []  # per-agent: [[eps_0, eps_1, ...], ...]

        # Agent colours for M4 subplot — match updated UAV_COLORS (no white)
        self._agent_colors = ["#1E90FF", "cyan", "#ff44ff",
                               "yellow", "#00ff88", "orange"]

        plt.ion()
        # 2×2 grid — equal subplot sizes
        self._fig, axes = plt.subplots(
            2, 2,
            figsize=(14, 10),
            gridspec_kw={"wspace": 0.38, "hspace": 0.48},
        )
        # Flatten row-major: TL=M1, TR=M2, BL=M3, BR=M4
        self._axs = [axes[0, 0], axes[0, 1], axes[1, 0], axes[1, 1]]
        self._fig.suptitle("Thesis Evaluation — Live Metrics", fontsize=13, fontweight="bold")

        # All 4 plots use auto-scaling y-axis so no data is ever clipped.
        configs = [
            ("#e63946",
             "M1  Mission-Averaged Team Ergodic Metric  ε(T)\n"
             "[time-avg ck vs time-avg φ — lower → planner tracks φ]",
             "ε(T)"),
            ("#2a9d8f",
             "M2  Fire Coverage Ratio  FCR(t) = |O(t) ∩ F_t| / |F_t|\n"
             "[higher → more fire cells observed]",
             "FCR(t)"),
            ("#f4a261",
             "M3  Belief Map Entropy  H̄(t) = H(t)/H(0)\n"
             "[lower → less uncertainty about fire state]",
             "H̄(t) = H(t)/H(0)"),
        ]
        self._lines: List = []
        for ax, (color, title, ylabel) in zip(self._axs[:3], configs):
            ax.set_title(title, fontsize=8.5)
            ax.set_xlabel("Simulation step  t", fontsize=9)
            ax.set_ylabel(ylabel, fontsize=9)
            ax.set_xlim(0, duration)
            ax.grid(True, alpha=0.3)
            ax.autoscale(enable=True, axis="y")
            line, = ax.plot([], [], color=color, linewidth=2.0)
            self._lines.append(line)

        # ── M4 — Individual Agent Ergodic Cost ────────────────────────────
        ax4 = self._axs[3]
        ax4.set_title(
            "M4  Individual Agent Ergodic Cost  ε_i(T)\n"
            "[per-agent time-avg ck_i vs time-avg φ — lower → agent tracks φ]",
            fontsize=8.5,
        )
        ax4.set_xlabel("Simulation step  t", fontsize=9)
        ax4.set_ylabel("ε_i(T)", fontsize=9)
        ax4.set_xlim(0, duration)
        ax4.autoscale(enable=True, axis="y")
        ax4.grid(True, alpha=0.3)
        self._m4_lines: List = []
        for i in range(num_uavs):
            c = self._agent_colors[i % len(self._agent_colors)]
            line_i, = ax4.plot([], [], color=c, linewidth=2.0,
                                label=f"UAV {i + 1}")
            self._m4_lines.append(line_i)
        ax4.legend(fontsize=8, loc="upper right", framealpha=0.75)

        try:
            self._fig.canvas.manager.window.wm_geometry("+0+0")
        except Exception:
            pass
        self._fig.canvas.draw()
        plt.pause(0.001)

    def update(self, t: int, m1: float, m2: float, m3: float,
               m4_per_agent: List[float]):
        self.times.append(t)
        self.m1_hist.append(m1)
        self.m2_hist.append(m2)
        self.m3_hist.append(m3 if np.isfinite(m3) else np.nan)
        self.m4_hist.append(list(m4_per_agent))

        ts   = np.array(self.times)
        xmax = max(10, int(ts[-1]) + 1)
        for ax in self._axs:
            ax.set_xlim(0, xmax)

        # ── Update M1, M2, M3 — autoscale y after setting data ────────────
        hists = [self.m1_hist, self.m2_hist, self.m3_hist]
        for ax, line, hist in zip(self._axs[:3], self._lines, hists):
            line.set_data(ts, hist)
            finite = [v for v in hist if np.isfinite(v)]
            if len(finite) >= 2:
                lo, hi = min(finite), max(finite)
                margin = max((hi - lo) * 0.12, 1e-6)
                ax.set_ylim(lo - margin, hi + margin)

        # ── Update M4 per-agent lines — autoscale y ────────────────────────
        ax4 = self._axs[3]
        all_vals: List[float] = []
        for i, line_i in enumerate(self._m4_lines):
            agent_series = [row[i] for row in self.m4_hist if len(row) > i]
            line_i.set_data(ts[:len(agent_series)], agent_series)
            all_vals.extend(v for v in agent_series if np.isfinite(v))
        if len(all_vals) >= 2:
            lo, hi = min(all_vals), max(all_vals)
            margin = max((hi - lo) * 0.12, 1e-6)
            ax4.set_ylim(lo - margin, hi + margin)

        self._fig.canvas.draw_idle()
        plt.pause(0.001)


