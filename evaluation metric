def compute_initial_entropy(belief_map: np.ndarray) -> float:
    b = np.clip(belief_map, 1e-12, 1.0)
    return float(np.sum(-np.sum(b * np.log2(b), axis=-1)))


def compute_m1_ergodic(
    ck_bar_mission: np.ndarray,
    phi_bar_mission: np.ndarray,
    ergodic_cache: "ErgodicCache",
) -> float:
    """
    M1 — Mission-Averaged Team Ergodic Metric  ε(T).

        ε(T) = Σ_k Λ_k ( ck̄_mission_team_k(T) − φ̄_mission_k(T) )²

    ck̄_mission_team = mean over UAVs of their unbounded running-mean
                      Fourier basis values of executed positions.
    φ̄_mission       = unbounded running mean of pre-step φ_k.

    Both are smooth (running averages), so orbital oscillation and per-step
    belief noise cancel. Converges to 0 at rate O(1/T) when SVGD tracks φ.

    Sources: Mathew & Mezić 2011 Eq.5; Mezić 2004; Prabhakar et al. 2015.
    """
    team_ck = np.mean(ck_bar_mission, axis=0)          # (K,)
    return float(np.sum(ergodic_cache.spectral_weights * (team_ck - phi_bar_mission) ** 2))


def compute_m2_fcr(env: "FinalWildfireMonitoringEnv") -> float:
    """M2: FCR(t) = |O(t) ∩ F_t| / |F_t|. Chen et al. 2024 Eq.21."""
    fire_mask = (env.true_state_map == FIRE)
    n_fire    = int(np.sum(fire_mask))
    if n_fire == 0:
        return 1.0
    return float(np.sum(env.cumulative_observed_mask & fire_mask)) / float(n_fire)


def compute_m3_entropy(env: "FinalWildfireMonitoringEnv", H_0: float) -> float:
    """M3: H̄(t) = H(t)/H(0). Thrun et al. 2005 Eq.2.22."""
    b   = np.clip(env.belief_map, 1e-12, 1.0)
    H_t = float(np.sum(-np.sum(b * np.log2(b), axis=-1)))
    return H_t / H_0 if H_0 > 1e-12 else 0.0


def compute_m4_per_agent(
    ck_bar_mission: np.ndarray,
    phi_bar_mission: np.ndarray,
    ergodic_cache: "ErgodicCache",
) -> List[float]:
    """
    M4 — Individual Agent Ergodic Cost  ε_i(T).

        ε_i(T) = Σ_k Λ_k ( ck̄_mission_i_k(T) − φ̄_mission_k(T) )²

    Same logic as M1 (mission-averaged ergodic metric) but computed
    independently for each agent i rather than using the team mean.
    Lower means that agent i's time-averaged trajectory tracks φ̄ well.

    Returns: list of per-agent ergodic costs (length = num_uavs).
    """
    per_agent: List[float] = []
    for i in range(ck_bar_mission.shape[0]):
        cost_i = float(
            np.sum(ergodic_cache.spectral_weights * (ck_bar_mission[i] - phi_bar_mission) ** 2)
        )
        per_agent.append(cost_i)
    return per_agent



