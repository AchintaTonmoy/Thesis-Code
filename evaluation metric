class ResultsSaver:
    def __init__(self, results_dir: str):
        os.makedirs(results_dir, exist_ok=True)
        self.results_dir = results_dir
        self.records: List[dict] = []

    def record(self, t: int, m1: float, m2: float, m3: float,
               m4_per_agent: List[float]):
        row: dict = {"t": t, "M1_ergodic_eps": m1,
                     "M2_fire_coverage_fcr": m2,
                     "M3_belief_entropy_Hn": m3}
        for i, v in enumerate(m4_per_agent):
            row[f"M4_agent{i+1}_ergodic_eps"] = v
        self.records.append(row)

    def save_csv(self):
        path = os.path.join(self.results_dir, "metrics.csv")
        if not self.records: return
        with open(path, "w", newline="") as f:
            w = csv.DictWriter(f, fieldnames=self.records[0].keys())
            w.writeheader(); w.writerows(self.records)
        print(f"[ResultsSaver] CSV saved → {path}")

    def save_final_plots(self):
        if not self.records: return
        ts  = np.array([r["t"]                    for r in self.records])
        m1s = np.array([r["M1_ergodic_eps"]       for r in self.records])
        m2s = np.array([r["M2_fire_coverage_fcr"] for r in self.records])
        m3s = np.array([r["M3_belief_entropy_Hn"] for r in self.records])

        # Detect number of agents from record keys
        agent_keys = sorted(k for k in self.records[0].keys()
                            if k.startswith("M4_agent"))

        _agent_colors = ["#1E90FF", "cyan", "#ff44ff",
                         "yellow", "#00ff88", "orange"]

        fig, axes = plt.subplots(2, 2, figsize=(14, 10),
                                 gridspec_kw={"wspace": 0.38, "hspace": 0.48})
        axs = [axes[0, 0], axes[0, 1], axes[1, 0], axes[1, 1]]
        fig.suptitle("Thesis Evaluation Results", fontsize=14, fontweight="bold")

        axs[0].plot(ts, m1s, color="#e63946", linewidth=2.0)
        axs[0].set_ylabel("ε(T)", fontsize=9)
        axs[0].set_xlabel("Simulation step  T", fontsize=9)
        axs[0].set_title("M1  Mission-Averaged Team Ergodic Metric  ε(T)\n"
                         "[Mathew & Mezić 2011; time-avg ck vs time-avg φ]", fontsize=10)
        axs[0].grid(True, alpha=0.3)

        axs[1].plot(ts, m2s, color="#2a9d8f", linewidth=2.0)
        axs[1].set_ylabel("FCR(t)", fontsize=9)
        axs[1].set_xlabel("Simulation step  t", fontsize=9)
        axs[1].set_title("M2  Fire Coverage Ratio  FCR(t) = |O(t) ∩ F_t| / |F_t|\n"
                         "[Chen et al. 2024, Eq. 21]", fontsize=10)
        axs[1].grid(True, alpha=0.3)

        axs[2].plot(ts, m3s, color="#f4a261", linewidth=2.0)
        axs[2].set_ylabel("H̄(t) = H(t)/H(0)", fontsize=9)
        axs[2].set_xlabel("Simulation step  t", fontsize=9)
        axs[2].set_title("M3  Belief Map Entropy  H̄(t) = H(t)/H(0)\n"
                         "[Thrun et al. 2005, Eq. 2.22]", fontsize=10)
        axs[2].grid(True, alpha=0.3)

        # M4 — individual agent ergodic cost
        for idx, key in enumerate(agent_keys):
            vals = np.array([r[key] for r in self.records])
            axs[3].plot(ts, vals, color=_agent_colors[idx % len(_agent_colors)],
                        linewidth=2.0, label=f"UAV {idx + 1}")
        axs[3].set_ylabel("ε_i(T)", fontsize=9)
        axs[3].set_xlabel("Simulation step  t", fontsize=9)
        axs[3].set_title("M4  Individual Agent Ergodic Cost  ε_i(T)\n"
                         "[per-agent time-avg ck_i vs time-avg φ]", fontsize=10)
        axs[3].grid(True, alpha=0.3)
        axs[3].legend(fontsize=8, loc="upper right", framealpha=0.75)

        plt.tight_layout()
        path = os.path.join(self.results_dir, "metrics_final.png")
        fig.savefig(path, dpi=150, bbox_inches="tight")
        plt.close(fig)
        print(f"[ResultsSaver] Final plot saved → {path}")

    def print_summary(self):
        if not self.records: return
        m1s = [r["M1_ergodic_eps"]       for r in self.records]
        m2s = [r["M2_fire_coverage_fcr"] for r in self.records]
        m3s = [r["M3_belief_entropy_Hn"] for r in self.records if np.isfinite(r["M3_belief_entropy_Hn"])]
        print("\n" + "=" * 62)
        print("  EXPERIMENT SUMMARY")
        print("=" * 62)
        print(f"  Steps recorded          : {len(self.records)}")
        print(f"  M1  ε(T)   — first 50   : {np.mean(m1s[:50]):.6f}")
        print(f"  M1  ε(T)   — last  50   : {np.mean(m1s[-50:]):.6f}")
        print(f"  M1  reduction           : {100*(m1s[0]-m1s[-1])/max(m1s[0],1e-9):.1f}%")
        print(f"  M2  FCR    — final      : {m2s[-1]:.4f}")
        if m3s:
            print(f"  M3  H̄(t)  — initial    : {m3s[0]:.4f}")
            print(f"  M3  H̄(t)  — final      : {m3s[-1]:.4f}")
            print(f"  M3  reduction           : {100*(m3s[0]-m3s[-1])/max(m3s[0],1e-9):.1f}%")
        print("=" * 62 + "\n")


# ==============================================================================
#  BUILD PARAMS
# ==============================================================================

def build_params(cfg: ExperimentConfig):
    tp = TransitionParams(belief_seed_cap=cfg.belief_seed_cap,
                          belief_seed_floor=cfg.belief_seed_floor,
                          tau_fire=cfg.tau_fire, tau_burn=cfg.tau_burn)
    sp = SensorParams(pm=cfg.pm, fov_radius=cfg.fov_radius,
                      log_odds_clamp=cfg.log_odds_clamp)
    pp = PlannerParams(horizon=cfg.horizon, num_particles=cfg.num_particles,
                       svgd_iters=cfg.svgd_iters, step_size=cfg.step_size,
                       bandwidth=cfg.bandwidth, dt=cfg.dt, v0=cfg.v0,
                       omega_max=cfg.omega_max, basis_order_x=cfg.basis_order_x,
                       basis_order_y=cfg.basis_order_y, ergodic_lambda=cfg.ergodic_lambda,
                       fd_eps=cfg.fd_eps, control_effort_weight=cfg.control_effort_weight,
                       omega_prior_sigma=cfg.omega_prior_sigma, prior_weight=cfg.prior_weight,
                       svgd_init_sigma=cfg.svgd_init_sigma,
                       svgd_warmstart_jitter=cfg.svgd_warmstart_jitter,
                       separation_distance=cfg.separation_distance,
                       separation_weight=cfg.separation_weight,
                       boundary_distance=cfg.boundary_distance,
                       boundary_weight=cfg.boundary_weight,
                       consensus_rounds=cfg.consensus_rounds,
                       init_boundary_margin=cfg.init_boundary_margin,
                       memory_horizon_multiplier=cfg.memory_horizon_multiplier)
    fp = FireParams(num_ign_points=cfg.num_ign_points,
                    radiation_radius=cfg.radiation_radius,
                    weak_fire_threshold=cfg.weak_fire_threshold,
                    flame_height=cfg.flame_height, flame_angle=cfg.flame_angle,
                    hotspot_patch_size=cfg.hotspot_patch_size,
                    hotspot_min_separation=cfg.hotspot_min_separation,
                    hotspot_border_margin=cfg.hotspot_border_margin,
                    decay_rate=cfg.decay_rate, max_fuel_coeff=cfg.max_fuel_coeff,
                    avg_wind_speed=cfg.avg_wind_speed,
                    avg_wind_direction=cfg.avg_wind_direction,
                    base_prior=cfg.base_prior)
    return tp, sp, pp, fp


# ==============================================================================
#  MAIN EXPERIMENT LOOP
# ==============================================================================

def run_experiment(cfg: ExperimentConfig):
    """
    Experiment loop with fully corrected M1.

    LOOP TIMING (critical for correctness):
      Step 1: phi_at_planning = obs["phi_map"].copy()   ← pre-step EID
      Step 2: phi_bar_mission += phi_k(phi_at_planning) ← accumulate φ̄
      Step 3: SVGD planning against phi_at_planning
      Step 4: env.step() → robots move, belief updated, obs refreshed
      Step 5: ck_bar (planner EMA)     updated from executed position
              ck_bar_mission (M1 avg)  updated from executed position
      Step 6: mission_steps += 1
      Step 7: M1 = Σ_k Λ_k (mean_i[ck_bar_mission_i] - phi_bar_mission)²
      Step 8: M2, M3 from updated obs
    """

    tp, sp, pp, fp = build_params(cfg)

    env = FinalWildfireMonitoringEnv(world_size=cfg.world_size, duration=cfg.duration,
                                     fireAreas_Num=cfg.fire_areas_num, seed=cfg.seed)
    init_states = generate_uav_initial_states(num_uavs=cfg.num_uavs,
                                               map_size=cfg.world_size,
                                               boundary_margin=cfg.init_boundary_margin)
    obs = env.reset(transition_params=tp, sensor_params=sp, planner_params=pp,
                    fire_params=fp, init_states=init_states, num_uavs=cfg.num_uavs)

    H_0 = compute_initial_entropy(obs["belief_map"])
    ergodic_cache = ErgodicCache(world_size_x=cfg.world_size, world_size_y=cfg.world_size,
                                 order_x=cfg.basis_order_x, order_y=cfg.basis_order_y)

    num_uavs = env.num_uavs
    K        = ergodic_cache.num_basis
    M_ERG    = int(round(cfg.memory_horizon_multiplier * cfg.horizon))

    # ── Planner state (unchanged) ──────────────────────────────────────────
    warm_omegas     = np.zeros((num_uavs, cfg.horizon), dtype=float)
    local_ck_memory = np.zeros((num_uavs, K), dtype=float)
    ck_bar          = np.zeros((num_uavs, K), dtype=float)  # EMA, capped at M_ERG
    steps_in_memory = 0

    # ── M1 measurement state (separate, unbounded) ─────────────────────────
    # ck_bar_mission: unbounded running mean of executed Fourier basis values.
    #   Separate from ck_bar (planner EMA). No M_ERG cap.
    # phi_bar_mission: unbounded running mean of pre-step φ_k.
    # mission_steps: unbounded counter (no cap).
    ck_bar_mission  = np.zeros((num_uavs, K), dtype=float)
    phi_bar_mission = np.zeros(K, dtype=float)
    mission_steps   = 0

    for i in range(num_uavs):
        ref = rollout_unicycle(x0=obs["robot_states"][i], omega_seq=warm_omegas[i],
                               dt=cfg.dt, world_size=cfg.world_size, v0=cfg.v0)[:, :2]
        local_ck_memory[i] = ergodic_cache.trajectory_fourier_coefficients(ref)

    consensus_ck = fully_connected_ck_consensus(local_ck_memory, rounds=cfg.consensus_rounds)

    metrics_win = LiveMetricsWindow(duration=cfg.duration, num_uavs=num_uavs)
    spatial_win = LiveSpatialWindow(world_size=cfg.world_size, num_uavs=num_uavs,
                                    fov_radius=cfg.fov_radius)
    saver = ResultsSaver(results_dir=cfg.results_dir)

    print(f"\n[eval] {cfg.duration} steps | {num_uavs} UAVs | seed={cfg.seed}")
    print(f"[eval] H₀={H_0:.2f} bits | M_ERG={M_ERG} | H={cfg.horizon} | K={K}\n")

    for step in range(cfg.duration):

        # ── 1. Capture pre-step φ ──────────────────────────────────────────
        phi_at_planning = obs["phi_map"].copy()

        # ── 2. Accumulate φ̄_mission (unbounded) from pre-step φ ───────────
        # MUST happen before env.step() which overwrites obs["phi_map"].
        phi_k_t = ergodic_cache.phi_fourier_coefficients(phi_at_planning)
        if mission_steps == 0:
            phi_bar_mission = phi_k_t.copy()
        else:
            phi_bar_mission = (mission_steps * phi_bar_mission + phi_k_t) / (mission_steps + 1)

        # ── 3. Reference rollouts for neighbour separation penalty ─────────
        ref_rollouts = [
            rollout_unicycle(x0=obs["robot_states"][i], omega_seq=warm_omegas[i],
                             dt=cfg.dt, world_size=cfg.world_size, v0=cfg.v0)[:, :2]
            for i in range(num_uavs)
        ]

        # ── 4. SVGD planning ───────────────────────────────────────────────
        best_omegas      = np.zeros((num_uavs, cfg.horizon), dtype=float)
        local_ck_updates = np.zeros_like(local_ck_memory)

        for i in range(num_uavs):
            nbr_cks   = [consensus_ck[j].copy() for j in range(num_uavs) if j != i]
            nbr_trajs = [ref_rollouts[j]         for j in range(num_uavs) if j != i]

            best_omega_i, _, _, best_ck_i = svgd_optimize_omega(
                x0=obs["robot_states"][i],
                phi_map=phi_at_planning,        # ← pre-step φ
                planner_params=pp,
                rng=env.rng,
                ergodic_cache=ergodic_cache,
                initial_omega=warm_omegas[i],
                neighbor_cks=nbr_cks,
                neighbor_reference_trajs=nbr_trajs,
                ck_bar_i=ck_bar[i],
                steps_in_memory=steps_in_memory,
            )
            best_omegas[i]      = best_omega_i
            local_ck_updates[i] = best_ck_i

        # ── 5. Consensus and environment step ─────────────────────────────
        local_ck_memory = local_ck_updates.copy()
        consensus_ck    = fully_connected_ck_consensus(local_ck_memory, rounds=cfg.consensus_rounds)

        obs = env.step(best_omegas[:, 0], pp)

        # ── 6. Update both ck_bar variants from executed position ──────────
        for i in range(num_uavs):
            executed_pos = obs["robot_states"][i, :2].reshape(1, 2)
            ck_exec      = ergodic_cache.trajectory_fourier_coefficients(executed_pos)

            # Planner EMA (M_ERG-capped — keeps planner reactive to recent φ)
            old_n     = steps_in_memory
            new_n     = steps_in_memory + 1
            ck_bar[i] = (old_n * ck_bar[i] + ck_exec) / new_n

            # Mission running average (unbounded — for M1 measurement only)
            if mission_steps == 0:
                ck_bar_mission[i] = ck_exec.copy()
            else:
                ck_bar_mission[i] = (mission_steps * ck_bar_mission[i] + ck_exec) / (mission_steps + 1)

        steps_in_memory = min(steps_in_memory + 1, M_ERG)
        mission_steps  += 1

        for i in range(num_uavs):
            warm_omegas[i] = shift_omega_horizon(best_omegas[i], fill_zero=True)

        # ── 7. Compute M1 ─────────────────────────────────────────────────
        # Both ck_bar_mission and phi_bar_mission are smooth running averages.
        # Orbital oscillation and per-step belief noise cancel in both averages.
        m1 = compute_m1_ergodic(ck_bar_mission, phi_bar_mission, ergodic_cache)

        # ── 8. Compute M2, M3 ─────────────────────────────────────────────
        m2 = compute_m2_fcr(env)
        m3 = compute_m3_entropy(env, H_0)

        # ── 9. Compute M4 — individual agent ergodic costs ────────────────
        # Same formula as M1 but per-agent: ε_i = Σ_k Λ_k (ck̄_i - φ̄)²
        m4_per_agent = compute_m4_per_agent(ck_bar_mission, phi_bar_mission, ergodic_cache)

        t = env.t
        agent_str = "  ".join(f"UAV{i+1}={v:.5f}" for i, v in enumerate(m4_per_agent))
        print(f"  t={t:04d}  M1 ε={m1:.5f}  M2 FCR={m2:.4f}  M3 H̄={m3:.4f}  M4 [{agent_str}]")

        metrics_win.update(t, m1, m2, m3, m4_per_agent)
        spatial_win.update(env, t=t)
        saver.record(t, m1, m2, m3, m4_per_agent)

        if len(env.active_fronts) == 0 and np.sum(env.true_intensity_map) <= 0.0:
            print(f"\n[eval] Wildfire extinguished at t={t}. Stopping early.")
            break

    saver.print_summary()
    if cfg.save_csv:   saver.save_csv()
    if cfg.save_plots: saver.save_final_plots()
    print("[eval] Done. Close plot windows to exit.")
    plt.ioff(); plt.show()


